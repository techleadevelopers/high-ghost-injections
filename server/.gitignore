# ============================================================
# RUST / CARGO
# ============================================================
/target/
**/*.rs.bk
*.pdb
*.exp
*.lib
*.dll
*.exe
*.rlib
*.rmeta
Cargo.lock

# ============================================================
# DATABASE FILES (SENSITIVE)
# ============================================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
/data/
/database/
*.sql
*.sqlite

# ============================================================
# CONFIGURATION FILES (SENSITIVE)
# ============================================================
config.toml
.env
.env.local
.env.production
*.env
*.toml
!Cargo.toml
!config.toml.example

# ============================================================
# CERTIFICATES AND KEYS (SENSITIVE)
# ============================================================
/certs/
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.der

# ============================================================
# PAYLOADS (BINÁRIOS)
# ============================================================
/payloads/*.exe
/payloads/*.dll
/payloads/*.bin
/payloads/*.ps1
!payloads/*.ps1.example
!payloads/README.md

# ============================================================
# LOGS (SENSITIVE)
# ============================================================
*.log
/logs/
/data/logs/
*.log.*
*.log.gz
*.log.zip

# ============================================================
# EXFILTRATED DATA (EXTREMELY SENSITIVE)
# ============================================================
/data/exfils/
/data/victims/
/data/alvos/
/data/dumps/
/exfils/

# ============================================================
# TEMPORARY FILES
# ============================================================
*.tmp
*.temp
*.bak
*.backup
*.old
*.swp
*.swo
*~
*.pid

# ============================================================
# IDE AND EDITOR FILES
# ============================================================
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
.DS_Store
.vs/
*.code-workspace

# ============================================================
# OS GENERATED FILES
# ============================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.dSYM/
*.dSYM.zip

# ============================================================
# DOCKER
# ============================================================
.docker/
docker-compose.override.yml
*.dockerignore

# ============================================================
# TESTING AND COVERAGE
# ============================================================
coverage/
*.gcda
*.gcno
*.lcov

# ============================================================
# DEPLOYMENT
# ============================================================
*.tar.gz
*.zip
*.deb
*.rpm
dist/
release/

# ============================================================
# RAILWAY / CLOUD
